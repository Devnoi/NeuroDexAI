PORT=5001

# Optional MongoDB fallback
MONGODB_URI=mongodb://localhost:27017/rit_db

# Supabase storage mode. When both values are set, backend reads/writes patients
# and sessions through Supabase REST API instead of MongoDB.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
